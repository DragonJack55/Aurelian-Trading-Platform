    function isValid(value) {
        return value !== null && value !== undefined && value !== "" && value.toLowerCase() !== "none";
    }

    function detectUserDevice() {
        const ua = navigator.userAgent.toLowerCase();

        if (/android/.test(ua)) return 'android';
        if (/iphone|ipod/.test(ua)) return 'ios';
        if (/ipad/.test(ua)) return 'ipad';
        if (/windows phone/.test(ua)) return 'windows_phone';
        if (/mac|windows|linux/.test(ua) && !/mobile/.test(ua)) return 'desktop';

        return 'unknown';
    }

    //Initializing Smart Script arguments
    let oneLinkURL = "https://myhfapp.hfm.com/XIQ4";
    let mediaSource = {
        keys: ["utm_source"],
        defaultValue: "default_media_source"
    };

    let campaign = {
        keys: ["utm_campaign"],
        defaultValue: "default_campaign"
    };

    let utm_medium = {
        paramKey: "utm_medium",
        keys: ["utm_medium"],
        defaultValue: ""
    };

    let utm_keyword = {
        paramKey: "utm_keyword",
        keys: ["utm_keyword"],
        defaultValue: ""
    };

    let utm_content = {
        paramKey: "utm_content",
        keys: ["utm_content"],
        defaultValue: ""
    };

    let mcid = {
        paramKey: "mcid",
        keys: ["mcid"],
        defaultValue: ""
    };

    let refid = {
        paramKey: "refid",
        keys: ["refid"],
        defaultValue: ""
    };

    let mc_data = {
        paramKey: "mc_data",
        keys: ["mc_data"],
        defaultValue: ""
    };

    let utm_placement = {
        paramKey: "utm_placement",
        keys: ["utm_placement"],
        defaultValue: ""
    };

    let acid = {
        paramKey: "acid",
        keys: ["acid"],
        defaultValue: ""
    };

    let user_country_code = {
        paramKey: "user_country_code",
        keys: ["user_country_code"],
        defaultValue: "RW"
    };

    let custom_ss_ui = {
        paramKey: "af_ss_ui",
        defaultValue: "true"
    };

    let user_device = {
        param_key: "user_device",
        keys: ["user_device"],
        defaultValue: detectUserDevice()
    }


    let mediaSourceValue = mediaSource.defaultValue || null;
    let campaignValue = campaign.defaultValue || null;

    // Put all params in an array
    let allCustomParams = [
        utm_medium,
        utm_keyword,
        utm_content,
        mcid,
        refid,
        mc_data,
        utm_placement,
        acid,
        user_country_code,
        user_device,
        custom_ss_ui
    ];


    // Filter only valid params (assuming you want to check the defaultValue)
    let validCustomParams = allCustomParams.filter(function (param) {
        return isValid(param.defaultValue);
    });


    // Build afParameters dynamically
    let afParameters = {
        mediaSource: mediaSource,
        campaign: campaign,
        afCustom: validCustomParams
    };


    //Call the function after embedding the code through a global parameter on the window object called window.AF_SMART_SCRIPT.
    //Onelink URL is generated.
    let onelink_url_result = window.AF_SMART_SCRIPT.generateOneLinkURL({
        oneLinkURL: oneLinkURL,
        afParameters: afParameters
    });

    show_qr_ios = false;
    show_qr_default= true;
    
        url_ios = onelink_url_result.clickURL;
        show_qr_ios = true;
    

    show_qr_android = false;
    
        url_android = onelink_url_result.clickURL;
        show_qr_android = true
    

    const ios_links = document.querySelectorAll('[id=ios_link]');
    ios_links.forEach(link => link.href = url_ios);
    const android_links = document.querySelectorAll('[id=android_link]');
    android_links.forEach(link => link.href = url_android);

    if (show_qr_android) {
        const qrAndroids = document.querySelectorAll('[id=qrcode_android]');
        qrAndroids.forEach((el, index) => {
            const originalId = el.id; // "qrcode_android"
            const uniqueId = `${originalId}_${index}`;
            el.id = uniqueId;

            window.AF_SMART_SCRIPT.displayQrCode(uniqueId);

            el.id = originalId; // restore original
        });
    }

    if (show_qr_ios) {
        const qrIos = document.querySelectorAll('[id=qrcode_ios]');
        qrIos.forEach((el, index) => {
            const originalId = el.id; // "qrcode_ios"
            const uniqueId = `${originalId}_${index}`;
            el.id = uniqueId;

            window.AF_SMART_SCRIPT.displayQrCode(uniqueId);

            el.id = originalId; // restore original
        });
    }
    if (show_qr_default) {
        const qrDefaults = document.querySelectorAll('[id=qrcode_default]');
        qrDefaults.forEach((el, index) => {
            const originalId = el.id; // "qrcode_default"
            const uniqueId = `${originalId}_${index}`;
            el.id = uniqueId;

            window.AF_SMART_SCRIPT.displayQrCode(uniqueId);

            el.id = originalId; // restore original
        });
    }


</script>

<style>
    #qrcode_default canvas {
        height: 91px!important;
        width: 91px!important;
    }

    #qrcode_android canvas {
        margin-left: auto;
        margin-right: auto;
        height: 91px!important;
        width: 91px!important;
    }

    #qrcode_ios canvas,
    .qr-code-direct {
        margin-left: auto;
        margin-right: auto;
        height: 91px!important;
        width: 91px!important;
    }
</style>

    

    
    

    
    







